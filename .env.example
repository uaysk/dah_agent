APP_NAME=DAH Agent PoC
APP_ENV=local
DATABASE_PATH=/app/data/dah_poc.sqlite3
OPENAI_API_KEY=
OPENAI_BASE_URL=https://litellm.uaysk.com
OPENAI_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=low
OPENAI_TIMEOUT_SECONDS=30
PUBLIC_BASE_URL=https://dah.uaysk.com

GRAFANA_ADMIN_PASSWORD=change-me-before-running

# Temporal is optional for the default app path. Enable when running:
# docker compose --profile temporal up --build -d
TEMPORAL_ENABLED=false
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=dah-agent-task-queue
TEMPORAL_WORKFLOW_TIMEOUT_SECONDS=300

# Existing homelab K8s PostgreSQL reused by the Temporal server container.
TEMPORAL_DB_HOST=172.30.1.49
TEMPORAL_DB_PORT=5432
TEMPORAL_DB_USER=temporal
TEMPORAL_DB_PASSWORD=
TEMPORAL_DB_NAME=temporal
TEMPORAL_VISIBILITY_DB_NAME=temporal_visibility

# Existing homelab Redis Streams. Disabled by default so the API remains local-testable.
REDIS_STREAMS_ENABLED=false
REDIS_URL=redis://172.30.1.51:6379/0
REDIS_STREAM_PREFIX=dah
REDIS_STREAM_MAXLEN=10000
